{
  "name": "broadcast",
  "version": "0.1.0",
  "description": "Desktop BGM pet that plays Bilibili 合集 videos",
  "license": "MIT",
  "author": "cabiriawzy-hub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabiriawzy-hub/desktop-bgm-pet.git"
  },
  "homepage": "https://github.com/cabiriawzy-hub/desktop-bgm-pet",
  "bugs": "https://github.com/cabiriawzy-hub/desktop-bgm-pet/issues",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-vite build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "build": {
    "appId": "com.broadcast.app",
    "productName": "Broadcast",
    "mac": {
      "category": "public.app-category.music",
      "icon": "resources/icon.png",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "zip": {
      "artifactName": "${productName}-${version}-${arch}-mac.${ext}"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
